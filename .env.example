# Minecraft Manager Configuration
MCM_MINECRAFT_DIR=/opt/minecraft
MCM_VERSIONS_DIR=/opt/minecraft-versions
MCM_BACKUP_DIR=/var/backups/minecraft
MCM_STDIN_PIPE=/run/minecraft.stdin
MCM_SYSTEMD_UNIT=minecraft
MCM_JAVA_PORT=25565
MCM_BEDROCK_PORT=19132
MCM_DAILY_RETENTION=7
MCM_AUTO_UPDATE_ENABLED=false
MCM_BUILDS_TO_KEEP=5
MCM_HEALTH_CHECK_TIMEOUT=90
MCM_PLAYER_NOTIFY_SECONDS=30

# Set to true for local development (mock systemd, local paths)
MCM_DEV_MODE=false
